---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/ui/Section.astro";
---

<BaseLayout title="About • Cinematic Portfolio" description="About and principles.">
  <Section title="About" eyebrow="Principles">
    <div class="prose">
      <p>
        Cinematic dark neon, but performance-first. I prefer transform-only motion, avoid heavy blur filters, and always
        respect <code>prefers-reduced-motion</code>.
      </p>
      <ul>
        <li>Mobile smooth first (360px baseline)</li>
        <li>No layout shift: reserve space, avoid late-loading UI surprises</li>
        <li>Accessible focus states and semantic headings</li>
      </ul>
    </div>
  </Section>
</BaseLayout>

<style>
  .prose {
    max-width: 72ch;
    color: var(--c-muted);
    line-height: 1.75;
  }
  code {
    color: rgba(255, 255, 255, 0.85);
    background: rgba(255, 255, 255, 0.06);
    padding: 2px 6px;
    border-radius: 8px;
  }
</style>
