---
import { getCollection } from 'astro:content';
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/ui/Section.astro";
import Tag from "../../components/ui/Tag.astro";
import GlowDivider from "../../components/ui/GlowDivider.astro";

// 1. Generate a new path for every collection entry
export async function getStaticPaths() {
  const postEntries = await getCollection('blog');
  return postEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

// 2. For your template, you can get the entry directly from the prop
const { entry } = Astro.props;
const { Content } = await entry.render();

// Calculate reading time roughly
function getReadingTime(text: string) {
  const wordsPerMinute = 200;
  const words = text.split(/\s+/).length;
  const minutes = Math.ceil(words / wordsPerMinute);
  return `${minutes} min read`;
}
---

<BaseLayout 
  title={`${entry.data.title} • Blog`} 
  description={entry.data.description}
  ogImage={entry.data.heroImage}
>
  <Section 
    eyebrow={entry.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })} 
    title={entry.data.title}
  >
    <div class="meta flex items-center gap-4 text-white/50 text-sm mb-6 mt-2">
      <span>{entry.data.readingTime || getReadingTime(entry.body)}</span>
      <div class="flex gap-2">
        {entry.data.tags.map((tag: string, i: number) => (
          <Tag tone={i % 2 === 0 ? "cyan" : "neutral"}>{tag}</Tag>
        ))}
      </div>
    </div>
    <p class="text-xl text-white/70 lead mb-12" style="max-width: 65ch;">
      {entry.data.description}
    </p>

    {entry.data.heroImage && (
      <div class="mb-12 rounded-2xl overflow-hidden border border-white/10 shadow-[0_0_30px_rgba(0,229,255,0.1)]">
        <img src={entry.data.heroImage} alt={entry.data.title} class="w-full h-auto object-cover" />
      </div>
    )}
  </Section>

  <GlowDivider />

  <Section>
    <article class="prose prose-invert prose-cyan max-w-[70ch] mx-auto latex-format">
      <Content />
    </article>
  </Section>

  <GlowDivider />

  <Section>
    <div class="flex justify-between items-center py-8">
      <a href="/blog" class="text-cyan-400 hover:text-cyan-300 transition-colors font-medium flex items-center gap-2">
        <span>←</span> Back to all posts
      </a>
      <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(entry.data.title)}&url=${encodeURIComponent(Astro.url.href)}`} target="_blank" rel="noopener noreferrer" class="text-white/50 hover:text-white/90 transition-colors text-sm">
        Share on X
      </a>
    </div>
  </Section>
</BaseLayout>

<style is:global>
  /* Customizing standard Markdown/MDX Prose */
  .prose.latex-format p {
    color: rgba(255,255,255,0.7);
    line-height: 1.8;
    margin-bottom: 1.5em;
    font-size: 16px;
  }
  
  .prose.latex-format h2 {
    color: rgba(255,255,255,0.9);
    font-size: 1.5em;
    margin-top: 2em;
    margin-bottom: 1em;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .prose.latex-format pre {
    background: rgba(0,0,0,0.4) !important;
    border: 1px solid rgba(255,255,255,0.1);
    box-shadow: 0 4px 20px rgba(0,0,0,0.5);
    border-radius: 12px;
    padding: 1.5rem;
    margin: 2rem 0;
  }

  .prose.latex-format code {
    font-family: var(--font-mono);
    font-size: 0.85em;
  }

  .prose.latex-format a {
    color: var(--c-neon-cyan);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-color: rgba(0,229,255, 0.4);
    transition: all 0.2s;
  }

  .prose.latex-format a:hover {
    text-decoration-color: rgba(0,229,255, 1);
  }
</style>
