---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/ui/Section.astro";
import Button from "../components/ui/Button.astro";
---

<BaseLayout title="Contact • Cinematic Portfolio" description="Get in touch.">
  <Section title="Contact" eyebrow="Let’s talk">
    <div class="wrap">
      <p class="p">Send a short note about what you’re building. I’ll reply with timelines and a perf budget.</p>
      <div class="row">
        <Button href="mailto:hello@example.com" variant="primary" magnet={false}>Email</Button>
        <Button href="/projects" variant="ghost" magnet={false}>View Projects</Button>
      </div>
    </div>
  </Section>
</BaseLayout>

<style>
  .wrap {
    max-width: 72ch;
  }
  .p {
    margin: 0;
    color: var(--c-muted);
    line-height: 1.7;
  }
  .row {
    margin-top: 18px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
</style>
