---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/ui/Container.astro";
import Tag from "../../components/ui/Tag.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
if (!slug) {
  throw new Error("Missing project slug");
}

const projects = await getCollection("projects");
const entry = projects.find((p) => p.slug === slug);
if (!entry) {
  throw new Error(`Project not found: ${slug}`);
}

const { Content } = await render(entry);
const { title, summary, githubUrl, liveUrl, tags } = entry.data;
---

<BaseLayout title={`${title} • Project`} description={summary}>
  <article class="wrap">
    <Container>
      <header class="head">
        <div class="tagRow">
          <Tag tone="magenta">Case Study</Tag>
          {tags?.slice(0, 3).map((t, i) => (
            <Tag tone={i % 2 === 0 ? "cyan" : "neutral"}>{t}</Tag>
          ))}
        </div>

        <h1 class="h1" transition:name={`project-title-${slug}`}>{title}</h1>
        <p class="lede">{summary}</p>

        <div class="detailPoster" aria-hidden="true" transition:name={`project-poster-${slug}`}></div>

        {(githubUrl || liveUrl) && (
          <div class="links" aria-label="Project links">
            {githubUrl && (
              <a href={githubUrl} rel="noreferrer" target="_blank">
                GitHub
              </a>
            )}
            {liveUrl && (
              <a href={liveUrl} rel="noreferrer" target="_blank">
                Live
              </a>
            )}
          </div>
        )}
      </header>

      <div class="content">
        <Content />
      </div>
    </Container>
  </article>
</BaseLayout>

<style>
  .wrap {
    padding-block: clamp(40px, 7vw, 80px);
  }

  .head {
    max-width: 78ch;
  }

  .tagRow {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }

  .h1 {
    margin: 14px 0 10px;
    font-size: clamp(30px, 5vw, 46px);
    letter-spacing: var(--tracking-tight);
  }

  .lede {
    margin: 0;
    color: var(--c-muted);
    line-height: 1.7;
  }

  .detailPoster {
    height: 160px;
    margin-top: 18px;
    border-radius: var(--radius);
    border: 1px solid rgba(255, 255, 255, 0.10);
    background: radial-gradient(240px 200px at 20% 20%, rgba(50, 245, 255, 0.22), transparent 62%),
      radial-gradient(260px 220px at 75% 30%, rgba(255, 53, 213, 0.18), transparent 66%),
      radial-gradient(120% 160% at 30% 10%, rgba(124, 92, 255, 0.14), transparent 60%),
      rgba(255, 255, 255, 0.02);
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.25);
  }

  .links {
    display: flex;
    gap: 12px;
    margin-top: 14px;
  }

  .links a {
    color: rgba(50, 245, 255, 0.85);
    text-decoration: none;
    border-bottom: 1px solid rgba(50, 245, 255, 0.25);
  }

  .links a:hover {
    border-bottom-color: rgba(50, 245, 255, 0.6);
  }

  .content {
    margin-top: 26px;
    max-width: 78ch;
    color: var(--c-muted);
    line-height: 1.8;
  }

  .content :global(h2) {
    margin: 22px 0 10px;
    color: rgba(255, 255, 255, 0.9);
    font-size: 18px;
    letter-spacing: var(--tracking-tight);
  }

  .content :global(p) {
    margin: 0 0 12px;
  }

  .content :global(ul) {
    margin: 0 0 12px;
    padding-left: 18px;
  }
</style>
