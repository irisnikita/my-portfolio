---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/ui/Section.astro";
import { site } from "../../data/site";
---

<BaseLayout title={`Projects • ${site.name}`} description={`${site.tagline} • ${site.location}`}>
  <Section title="Selected work" eyebrow="Coming soon">
    <div class="empty">
      <p class="p">
        Projects are being curated. To avoid inventing details, this page is temporarily an empty state.
      </p>

      <div class="todo" aria-label="To publish projects, prepare:">
        <h3 class="h3">To publish case studies, prepare:</h3>
        <ul>
          <li>Project name + timeframe + your role</li>
          <li>Stack + constraints</li>
          <li>1–2 outcomes/metrics (optional)</li>
          <li>Links (live/GitHub) + 2–3 screenshots</li>
        </ul>
      </div>

      <a class="cta" href="/#contact">Get in touch →</a>
    </div>
  </Section>
</BaseLayout>

<style>
  .empty {
    max-width: 78ch;
  }

  .p {
    margin: 0;
    color: var(--c-muted);
    line-height: 1.75;
  }

  .todo {
    margin-top: 16px;
    border: 1px solid rgba(255, 255, 255, 0.10);
    background: rgba(255, 255, 255, 0.03);
    border-radius: var(--radius);
    padding: 14px 14px;
  }

  .h3 {
    margin: 0 0 10px;
    font-size: 15px;
    letter-spacing: var(--tracking-tight);
    color: rgba(255, 255, 255, 0.88);
  }

  ul {
    margin: 0;
    padding-left: 18px;
    color: rgba(255, 255, 255, 0.74);
    line-height: 1.7;
  }

  .cta {
    display: inline-block;
    margin-top: 16px;
    color: rgba(0, 229, 255, 0.88);
    text-decoration: none;
    border-bottom: 1px solid rgba(0, 229, 255, 0.25);
  }

  .cta:hover {
    border-bottom-color: rgba(0, 229, 255, 0.6);
  }
</style>
