---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/ui/Section.astro";
import ProjectCard from "../../components/sections/ProjectCard.astro";
import { getCollection } from "astro:content";
import { site } from "../../data/site";

const projects = (await getCollection("projects")).sort(
  (a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0)
);
---

<BaseLayout title={`Projects • ${site.name}`} description={`${site.tagline} • ${site.location}`}>
  <Section title="Selected Work" eyebrow="Projects">
    <div class="grid" data-reveal-container="projects" data-reveal-stagger="80">
      {projects.map((project, i) => (
        <div data-reveal data-reveal-group="project">
          <ProjectCard
            title={project.data.title}
            summary={project.data.summary}
            slug={project.slug}
            tags={project.data.tags}
            index={i}
          />
        </div>
      ))}
    </div>

    <div class="cta">
      <a class="ctaLink" href="/#contact">Have a project in mind? Get in touch →</a>
    </div>
  </Section>
</BaseLayout>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .cta {
    margin-top: 28px;
  }

  .ctaLink {
    color: rgba(0, 229, 255, 0.88);
    text-decoration: none;
    border-bottom: 1px solid rgba(0, 229, 255, 0.25);
    font-size: 15px;
  }

  .ctaLink:hover {
    border-bottom-color: rgba(0, 229, 255, 0.6);
  }

  @media (max-width: 720px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
