---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/ui/Container.astro";
import Button from "../components/ui/Button.astro";
import Tag from "../components/ui/Tag.astro";
import NeonGridParallax from "../components/hero/NeonGridParallax.astro";
import ContactSection from "../components/sections/ContactSection.astro";
import TestimonialsSection from "../components/sections/TestimonialsSection.astro";
import { site } from "../data/site";

const title = `${site.name} — ${site.title}`;
---

<BaseLayout title={title} description={`${site.tagline} • ${site.location}`}>
  <section class="hero">
    <NeonGridParallax />
    <div class="vignette" />
    <div class="grain" />

    <Container>
      <div class="heroInner">
        <div class="stack">
          <Tag tone="cyan">{site.tagline}</Tag>
          <h1 class="h1">{site.name}</h1>
          <p class="sub">{site.bio} • {site.location}</p>

          <div class="ctaRow">
            <Button href="/projects" variant="primary">View Work</Button>
            <Button href="/#contact" variant="ghost">Contact</Button>
          </div>

          <ul class="proof" aria-label="Proof points" data-reveal-container="heroProof" data-reveal-stagger="90">
            <li data-reveal data-reveal-group="proof">{site.title}</li>
            <li data-reveal data-reveal-group="proof">{site.location}</li>
            <li data-reveal data-reveal-group="proof">Performance-first</li>
            <li data-reveal data-reveal-group="proof">Reduced-motion ready</li>
          </ul>

          <p class="meta">Transform-only motion • Reduced motion supported • Static-first</p>
        </div>
      </div>
    </Container>
  </section>

  <section class="below">
    <Container>
      <div class="grid">
        <div class="panel">
          <h2>Selected work</h2>
          <p>Case studies are being prepared (no invented details). If you want to collaborate, reach out.</p>
          <a class="textLink" href="/#contact">Get in touch →</a>
        </div>
        <div class="panel">
          <h2>About</h2>
          <p>My tools, principles, and the motion/perf rules I won’t compromise on.</p>
          <a class="textLink" href="/about">Read about me →</a>
        </div>
      </div>
    </Container>
  </section>

  <TestimonialsSection />

  <ContactSection />
</BaseLayout>

<style>
  .hero {
    position: relative;
    padding-block: clamp(56px, 10vw, 120px);
    overflow: hidden;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .heroInner {
    position: relative;
    z-index: 2;
    min-height: min(70vh, 640px);
    display: grid;
    align-items: center;
  }

  .stack {
    max-width: 56ch;
  }

  .h1 {
    margin: 16px 0 10px;
    font-size: clamp(34px, 6vw, 60px);
    line-height: 1.05;
    letter-spacing: var(--tracking-tight);
  }

  .sub {
    margin: 0;
    color: var(--c-muted);
    font-size: clamp(16px, 2.1vw, 19px);
    line-height: 1.6;
  }

  .ctaRow {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 22px;
  }

  .proof {
    margin: 18px 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .proof li {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.75);
    border: 1px solid rgba(255, 255, 255, 0.10);
    background: rgba(255, 255, 255, 0.03);
    padding: 7px 10px;
    border-radius: 999px;
  }

  .meta {
    margin-top: 16px;
    color: rgba(255, 255, 255, 0.55);
    font-size: 13px;
  }

  .below {
    padding-block: clamp(36px, 6vw, 72px);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .panel {
    border-radius: var(--radius);
    border: 1px solid rgba(255, 255, 255, 0.10);
    background: rgba(255, 255, 255, 0.03);
    padding: 18px 16px;
  }

  .panel h2 {
    margin: 0 0 6px;
    font-size: 18px;
    letter-spacing: var(--tracking-tight);
  }

  .panel p {
    margin: 0 0 10px;
    color: var(--c-muted);
    line-height: 1.55;
  }

  .textLink {
    color: rgba(50, 245, 255, 0.85);
    text-decoration: none;
  }
  .textLink:hover {
    text-decoration: underline;
  }

  @media (max-width: 720px) {
    .grid {
      grid-template-columns: 1fr;
    }
    .heroInner {
      min-height: auto;
    }
  }
</style>
