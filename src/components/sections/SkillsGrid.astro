---
import Tag from "../ui/Tag.astro";
import { skills } from "../../data/skills";
---

<div class="skillsGrid" data-reveal-container="skills" data-reveal-stagger="60">
  {skills.map((group) => (
    <div class="group" data-reveal data-reveal-group="skill">
      <h4 class="catLabel">{group.category}</h4>
      <div class="tags">
        {group.items.map((item, i) => (
          <Tag tone={i % 3 === 0 ? "cyan" : i % 3 === 1 ? "neutral" : "magenta"}>{item}</Tag>
        ))}
      </div>
    </div>
  ))}
</div>

<style>
  .skillsGrid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .group {
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.02);
    border-radius: var(--radius);
    padding: 18px 16px;
  }

  .catLabel {
    margin: 0 0 12px;
    font-size: 13px;
    font-weight: 650;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  @media (max-width: 600px) {
    .skillsGrid {
      grid-template-columns: 1fr;
    }
  }
</style>
