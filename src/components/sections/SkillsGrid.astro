---
import Tag from "../ui/Tag.astro";
import { skills } from "../../data/skills";
---

<div class="skillsGrid" data-reveal-container="skills" data-reveal-stagger="80">
  {
    skills.map((group, gi) => (
      <div class="group" data-reveal data-reveal-class="reveal-scale" data-reveal-group="skill">
        <h4 class="catLabel">{group.category}</h4>
        <div class="tags">
          {group.items.map((item, i) => (
            <span class="tagWrap" style={`--tag-delay: ${i * 50}ms`}>
              <Tag tone={i % 3 === 0 ? "cyan" : i % 3 === 1 ? "neutral" : "magenta"}>{item}</Tag>
            </span>
          ))}
        </div>
      </div>
    ))
  }
</div>

<style>
  .skillsGrid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .group {
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.02);
    border-radius: var(--radius);
    padding: 18px 16px;
    transition:
      border-color 220ms var(--ease-out),
      box-shadow 220ms var(--ease-out);
  }

  .group:hover {
    border-color: rgba(0, 229, 255, 0.15);
    box-shadow: 0 0 20px rgba(0, 229, 255, 0.06);
  }

  .catLabel {
    margin: 0 0 12px;
    font-size: 13px;
    font-weight: 650;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tagWrap {
    opacity: 0;
    transform: scale(0.7) translate3d(0, 8px, 0);
    animation: tagPop 400ms var(--ease-spring) forwards;
    animation-delay: var(--tag-delay, 0ms);
    animation-play-state: paused;
  }

  .group.is-revealed .tagWrap {
    animation-play-state: running;
  }

  @keyframes tagPop {
    to {
      opacity: 1;
      transform: scale(1) translate3d(0, 0, 0);
    }
  }

  @media (max-width: 600px) {
    .skillsGrid {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tagWrap {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>
