---
import Tag from "../ui/Tag.astro";
import { experience } from "../../data/experience";
---

<div class="timeline" data-reveal-container="experience" data-reveal-stagger="120">
  <div class="timelineLine" aria-hidden="true" />

  {experience.map((entry, idx) => (
    <div class="entry" data-reveal data-reveal-class="reveal-slide-right" data-reveal-group="exp">
      <div class="marker" aria-hidden="true">
        <div class="markerDot" />
        <div class="markerPulse" />
      </div>
      <div class="content">
        <p class="period">{entry.period}</p>
        <h4 class="role">{entry.role}</h4>
        <p class="company">{entry.company}</p>
        <p class="desc">{entry.description}</p>
        <div class="tags">
          {entry.tags.map((tag, i) => (
            <Tag tone={i % 2 === 0 ? "cyan" : "neutral"}>{tag}</Tag>
          ))}
        </div>
      </div>
    </div>
  ))}
</div>

<style>
  .timeline {
    position: relative;
    padding-left: 32px;
  }

  .timelineLine {
    position: absolute;
    left: 5px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(180deg, rgba(0, 229, 255, 0.35), rgba(124, 59, 255, 0.2), transparent);
    transform-origin: top center;
    transform: scaleY(0);
    animation: lineGrow 1.2s var(--ease-out) 0.3s forwards;
  }

  @keyframes lineGrow {
    to { transform: scaleY(1); }
  }

  .entry {
    position: relative;
    padding-bottom: 36px;
  }

  .entry:last-child {
    padding-bottom: 0;
  }

  .marker {
    position: absolute;
    left: -32px;
    top: 5px;
    width: 14px;
    height: 14px;
  }

  .markerDot {
    width: 12px;
    height: 12px;
    border-radius: 999px;
    background: radial-gradient(circle at 30% 30%, #fff, rgba(0, 229, 255, 0.8));
    box-shadow: 0 0 8px rgba(0, 229, 255, 0.35);
    position: relative;
    z-index: 1;
  }

  .markerPulse {
    position: absolute;
    inset: -4px;
    border-radius: 999px;
    border: 1px solid rgba(0, 229, 255, 0.3);
    opacity: 0;
  }

  .entry.is-revealed .markerPulse {
    animation: dotPulse 1.5s var(--ease-out) forwards;
  }

  @keyframes dotPulse {
    0% { transform: scale(0.5); opacity: 0.8; }
    70% { transform: scale(2); opacity: 0; }
    100% { transform: scale(2); opacity: 0; }
  }

  .period {
    margin: 0 0 4px;
    font-size: 13px;
    font-weight: 650;
    letter-spacing: 0.06em;
    color: rgba(0, 229, 255, 0.75);
    text-transform: uppercase;
  }

  .role {
    margin: 0 0 2px;
    font-size: 17px;
    letter-spacing: var(--tracking-tight);
    color: rgba(255, 255, 255, 0.92);
  }

  .company {
    margin: 0 0 8px;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.55);
  }

  .desc {
    margin: 0 0 10px;
    color: var(--c-muted);
    line-height: 1.7;
    max-width: 60ch;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  @media (prefers-reduced-motion: reduce) {
    .timelineLine {
      animation: none;
      transform: scaleY(1);
    }
    .markerPulse {
      display: none;
    }
  }
</style>
