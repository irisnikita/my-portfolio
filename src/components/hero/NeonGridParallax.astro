---
// Static neon grid backdrop for the hero.
// The previous scroll/pointer-driven parallax created too much main-thread work,
// so this version keeps the depth cues without runtime listeners or RAF loops.

const { class: className } = Astro.props;
---

<div class={["gridWrap", className].filter(Boolean).join(" ")} aria-hidden="true">
  <svg class="layer layerBack" viewBox="0 0 1200 600" preserveAspectRatio="none">
    <defs>
      <linearGradient id="g1" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0" stop-color="#00e5ff" stop-opacity="0.0"></stop>
        <stop offset="0.45" stop-color="#00e5ff" stop-opacity="0.18"></stop>
        <stop offset="1" stop-color="#ff2bd6" stop-opacity="0.08"></stop>
      </linearGradient>
      <pattern id="p1" width="40" height="40" patternUnits="userSpaceOnUse">
        <path d="M 40 0 L 0 0 0 40" fill="none" stroke="url(#g1)" stroke-width="1"></path>
      </pattern>
    </defs>
    <rect width="1200" height="600" fill="url(#p1)"></rect>
  </svg>

  <svg class="layer layerFront" viewBox="0 0 1200 600" preserveAspectRatio="none">
    <defs>
      <linearGradient id="g2" x1="1" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="#ff2bd6" stop-opacity="0.0"></stop>
        <stop offset="0.55" stop-color="#ff2bd6" stop-opacity="0.14"></stop>
        <stop offset="1" stop-color="#7c3bff" stop-opacity="0.10"></stop>
      </linearGradient>
      <pattern id="p2" width="56" height="56" patternUnits="userSpaceOnUse">
        <path d="M 56 0 L 0 0 0 56" fill="none" stroke="url(#g2)" stroke-width="1"></path>
      </pattern>
    </defs>
    <rect width="1200" height="600" fill="url(#p2)"></rect>
  </svg>

  <!-- Light sweep: slow diagonal, low opacity -->
  <div class="sweep"></div>

  <!-- Cursor hotspot: transform-only (no filters). JS updates CSS vars. -->
  <div class="hotspot"></div>

  <!-- Interference layer: scanlines + tiny drift -->
  <div class="scan"></div>

  <div class="pulse"></div>
</div>

<style>
  .gridWrap {
    --hx: 0.5;
    --hy: 0.25;

    position: absolute;
    inset: -20% -10% -30% -10%;
    overflow: hidden;
    pointer-events: none;
    opacity: 0.86;
    mask-image: radial-gradient(
      130% 120% at calc(var(--hx) * 100%) calc(var(--hy) * 100%),
      #000 10%,
      transparent 70%
    );
    -webkit-mask-image: radial-gradient(
      130% 120% at calc(var(--hx) * 100%) calc(var(--hy) * 100%),
      #000 10%,
      transparent 70%
    );
  }

  .layer {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    transform: translate3d(0, 0, 0);
  }

  .layerFront {
    opacity: 0.92;
  }

  /* Mobile perf: reduce to 1 grid layer (remove from paint) */
  @media (max-width: 720px) {
    .layerFront {
      display: none;
    }
  }

  .pulse {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(700px 420px at 50% 20%, rgba(50, 245, 255, 0.07), transparent 60%),
      radial-gradient(900px 520px at 60% 25%, rgba(255, 53, 213, 0.05), transparent 62%);
    opacity: 0.72;
  }

  .sweep {
    position: absolute;
    inset: -40%;
    background: linear-gradient(
      115deg,
      rgba(255, 255, 255, 0) 0%,
      rgba(0, 229, 255, 0.08) 42%,
      rgba(255, 43, 214, 0.06) 52%,
      rgba(255, 255, 255, 0) 70%
    );
    transform: translate3d(-8%, -6%, 0);
    opacity: 0.22;
  }

  .hotspot {
    position: absolute;
    inset: 0;
    opacity: 0.45;
    background: radial-gradient(
      520px 360px at calc(var(--hx) * 100%) calc(var(--hy) * 100%),
      rgba(0, 229, 255, 0.12),
      rgba(255, 43, 214, 0.06) 40%,
      transparent 62%
    );
  }

  .scan {
    position: absolute;
    inset: 0;
    opacity: 0.05;
    background-image: repeating-linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.35) 0px,
      rgba(255, 255, 255, 0.35) 1px,
      transparent 2px,
      transparent 6px
    );
    opacity: 0.035;
  }

  @media (prefers-reduced-motion: reduce) {
    .hotspot {
      opacity: 0;
    }
  }

  @media (hover: none), (pointer: coarse) {
    .hotspot {
      opacity: 0;
    }
  }
</style>
