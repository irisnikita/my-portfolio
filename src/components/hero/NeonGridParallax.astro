---
// CSS/SVG neon grid parallax (2 layers)
// Performance rules:
// - transform-only updates
// - requestAnimationFrame throttle
// - disabled when prefers-reduced-motion

const { class: className } = Astro.props;
---

<div class={['gridWrap', className].filter(Boolean).join(' ')} aria-hidden="true">
  <svg class="layer layerBack" viewBox="0 0 1200 600" preserveAspectRatio="none">
    <defs>
      <linearGradient id="g1" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0" stop-color="#32f5ff" stop-opacity="0.0" />
        <stop offset="0.45" stop-color="#32f5ff" stop-opacity="0.18" />
        <stop offset="1" stop-color="#ff35d5" stop-opacity="0.08" />
      </linearGradient>
      <pattern id="p1" width="40" height="40" patternUnits="userSpaceOnUse">
        <path d="M 40 0 L 0 0 0 40" fill="none" stroke="url(#g1)" stroke-width="1" />
      </pattern>
    </defs>
    <rect width="1200" height="600" fill="url(#p1)" />
  </svg>

  <svg class="layer layerFront" viewBox="0 0 1200 600" preserveAspectRatio="none">
    <defs>
      <linearGradient id="g2" x1="1" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="#ff35d5" stop-opacity="0.0" />
        <stop offset="0.55" stop-color="#ff35d5" stop-opacity="0.14" />
        <stop offset="1" stop-color="#7c5cff" stop-opacity="0.10" />
      </linearGradient>
      <pattern id="p2" width="56" height="56" patternUnits="userSpaceOnUse">
        <path d="M 56 0 L 0 0 0 56" fill="none" stroke="url(#g2)" stroke-width="1" />
      </pattern>
    </defs>
    <rect width="1200" height="600" fill="url(#p2)" />
  </svg>

  <div class="pulse" />
</div>

<script>
  const prefersReduced = window.matchMedia?.('(prefers-reduced-motion: reduce)')?.matches;
  if (!prefersReduced) {
    const root = document.currentScript?.previousElementSibling;
    if (root) {
      const back = root.querySelector('.layerBack');
      const front = root.querySelector('.layerFront');

      let raf = 0;
      let lastY = -1;

      const tick = () => {
        raf = 0;
        const y = window.scrollY || 0;
        if (y === lastY) return;
        lastY = y;

        // Keep it subtle; move less on mobile.
        const s = Math.min(1.0, window.innerWidth / 900);
        const backY = (y * 0.05) * s;
        const frontY = (y * 0.09) * s;

        // transform-only for perf
        back?.style.setProperty('transform', `translate3d(0, ${backY}px, 0)`);
        front?.style.setProperty('transform', `translate3d(0, ${frontY}px, 0)`);
      };

      const onScroll = () => {
        if (raf) return;
        raf = requestAnimationFrame(tick);
      };

      tick();
      window.addEventListener('scroll', onScroll, { passive: true });
    }
  }
</script>

<style>
  .gridWrap {
    position: absolute;
    inset: -20% -10% -30% -10%;
    overflow: hidden;
    pointer-events: none;
    opacity: 0.85;
    mask-image: radial-gradient(90% 70% at 50% 20%, #000 40%, transparent 78%);
  }

  .layer {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    will-change: transform;
    transform: translate3d(0, 0, 0);
  }

  .layerFront {
    opacity: 0.9;
  }

  .pulse {
    position: absolute;
    inset: 0;
    background: radial-gradient(700px 420px at 50% 20%, rgba(50, 245, 255, 0.08), transparent 60%),
      radial-gradient(900px 520px at 60% 25%, rgba(255, 53, 213, 0.06), transparent 62%);
    animation: pulse 5.5s cubic-bezier(0.22, 1, 0.36, 1) infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 0.6;
    }
    50% {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pulse {
      animation: none;
    }
  }
</style>
