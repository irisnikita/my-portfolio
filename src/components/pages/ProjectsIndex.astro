---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../ui/Section.astro";
import ProjectCard from "../sections/ProjectCard.astro";
import { getCollection } from "astro:content";
import { site } from "../../data/site";
import { getLangFromUrl, useTranslations, useTranslatedPath } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const projects = (await getCollection("projects")).sort(
  (a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0),
);
---

<BaseLayout
  title={`${t("projects.metaTitle")} • ${site.name}`}
  description={`${site.tagline} • ${site.location}`}
>
  <Section title={t("projects.sectionTitle")} eyebrow={t("projects.sectionEyebrow")}>
    <div class="grid" data-reveal-container="projects" data-reveal-stagger="80">
      {
        projects.map((project, i) => (
          <div data-reveal data-reveal-group="project">
            <ProjectCard
              title={project.data.title}
              summary={project.data.summary}
              slug={project.slug}
              tags={project.data.tags}
              index={i}
            />
          </div>
        ))
      }
    </div>

    <div class="cta">
      <a class="ctaLink" href={translatePath("/#contact")}>
        {t("projects.cta")}
      </a>
    </div>
  </Section>
</BaseLayout>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .cta {
    margin-top: 28px;
  }

  .ctaLink {
    color: rgba(0, 229, 255, 0.88);
    text-decoration: none;
    border-bottom: 1px solid rgba(0, 229, 255, 0.25);
    font-size: 15px;
  }

  .ctaLink:hover {
    border-bottom-color: rgba(0, 229, 255, 0.6);
  }

  @media (max-width: 720px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
