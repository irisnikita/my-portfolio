---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../ui/Section.astro";
import Tag from "../ui/Tag.astro";
import GlowDivider from "../ui/GlowDivider.astro";
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../../i18n/utils';

interface Props {
  entry: any;
}

const { entry } = Astro.props;
if (!entry) {
  throw new Error(`Blog entry not found or not passed to Component`);
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

function getReadingTime(text: string) {
  const wordsPerMinute = 200;
  const words = text.split(/\s+/).length;
  const minutes = Math.ceil(words / wordsPerMinute);
  return t('blog.readTime').replace('{minutes}', String(minutes));
}

const formattedDate = entry.data.pubDate.toLocaleDateString(
  lang === 'vi' ? "vi-VN" : "en-US",
  { year: "numeric", month: "short", day: "numeric" }
);
---

<BaseLayout 
  title={`${entry.data.title} • Blog`} 
  description={entry.data.description}
  ogImage={entry.data.heroImage}
>
  <Section 
    eyebrow={formattedDate} 
    title={entry.data.title}
  >
    <div class="meta flex items-center gap-4 text-white/50 text-sm mb-6 mt-2">
      <span>{entry.data.readingTime || getReadingTime(entry.body)}</span>
      <div class="flex gap-2">
        {entry.data.tags.map((tag: string, i: number) => (
          <Tag tone={i % 2 === 0 ? "cyan" : "neutral"}>{tag}</Tag>
        ))}
      </div>
    </div>
    <p class="text-xl text-white/70 lead mb-12" style="max-width: 65ch;">
      {entry.data.description}
    </p>

    {entry.data.heroImage && (
      <div class="mb-12 rounded-2xl overflow-hidden border border-white/10 shadow-[0_0_30px_rgba(0,229,255,0.1)]">
        <img src={entry.data.heroImage} alt={entry.data.title} class="w-full h-auto object-cover" />
      </div>
    )}
  </Section>

  <GlowDivider />

  <Section>
    <article class="prose prose-invert prose-cyan max-w-[70ch] mx-auto latex-format">
      <slot />
    </article>
  </Section>

  <GlowDivider />

  <Section>
    <div class="flex justify-between items-center py-8">
      <a href={translatePath("/blog")} class="text-cyan-400 hover:text-cyan-300 transition-colors font-medium flex items-center gap-2">
        <span>←</span> {t('blog.back')}
      </a>
      <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(entry.data.title)}&url=${encodeURIComponent(Astro.url.href)}`} target="_blank" rel="noopener noreferrer" class="text-white/50 hover:text-white/90 transition-colors text-sm">
        {t('blog.shareX')}
      </a>
    </div>
  </Section>
</BaseLayout>

<style is:global>
  /* Customizing standard Markdown/MDX Prose */
  .prose.latex-format p {
    color: rgba(255,255,255,0.7);
    line-height: 1.8;
    margin-bottom: 1.5em;
    font-size: 16px;
  }
  
  .prose.latex-format h2 {
    color: rgba(255,255,255,0.9);
    font-size: 1.5em;
    margin-top: 2em;
    margin-bottom: 1em;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .prose.latex-format pre {
    background: rgba(0,0,0,0.4) !important;
    border: 1px solid rgba(255,255,255,0.1);
    box-shadow: 0 4px 20px rgba(0,0,0,0.5);
    border-radius: 12px;
    padding: 1.5rem;
    margin: 2rem 0;
  }

  .prose.latex-format code {
    font-family: var(--font-mono);
    font-size: 0.85em;
  }

  .prose.latex-format a {
    color: var(--c-neon-cyan);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-color: rgba(0,229,255, 0.4);
    transition: all 0.2s;
  }

  .prose.latex-format a:hover {
    text-decoration-color: rgba(0,229,255, 1);
  }
</style>
