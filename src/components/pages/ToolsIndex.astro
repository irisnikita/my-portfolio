---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { site } from "../../data/site";
import { Image as ImageIcon, FileCode2, PaintBucket, FileJson, Link } from "lucide-react";
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const isVi = lang === 'vi';

const tools = [
  {
    id: "image-compressor",
    title: isVi ? "Nén Ảnh Thông Minh" : "Smart Image Compressor",
    description: isVi 
      ? "Nén kích thước ảnh trực tiếp trên trình duyệt bằng Web Worker mà không suy giảm chất lượng mắt thường."
      : "Compress images directly in your browser using a Web Worker without visible quality loss.",
    icon: ImageIcon,
    status: "ready", // ready, beta, planned
    href: translatePath("/tools/image-compressor")
  },
  {
    id: "svg-optimizer",
    title: isVi ? "Tối ưu hóa SVG" : "Beautiful SVG Optimizer",
    description: isVi
      ? "Dọn dẹp mã SVG, format lại code sạch đẹp và hiển thị preview thu nhỏ tiện lợi."
      : "Clean up SVG code, format it nicely, and preview it conveniently.",
    icon: FileCode2,
    status: "planned",
    href: translatePath("/tools#svg")
  },
  {
    id: "code-to-image",
    title: isVi ? "Chuyển Code thành Ảnh" : "Code to Image Generator",
    description: isVi
      ? "Chuyển đoạn code thành ảnh chụp nền phong cách macOS đẹp mắt để chia sẻ."
      : "Turn code snippets into beautiful macOS-style screenshots for sharing.",
    icon: Link,
    status: "planned",
    href: translatePath("/tools#code")
  },
  {
    id: "mesh-gradient",
    title: "CSS Mesh Gradient",
    description: isVi
      ? "Tạo các dải màu trộn lẫn ngẫu nhiên cực đẹp và copy CSS code ngay lập tức."
      : "Generate beautiful randomized blended gradients and copy the CSS code instantly.",
    icon: PaintBucket,
    status: "planned",
    href: translatePath("/tools#gradient")
  },
  {
    id: "json-formatter",
    title: "Smart JSON Formatter",
    description: isVi
      ? "Định dạng lại cấu trúc JSON lộn xộn, highlight cú pháp và kiểm tra lỗi thông minh."
      : "Format messy JSON structures, highlight syntax and smartly check for errors.",
    icon: FileJson,
    status: "planned",
    href: translatePath("/tools#json")
  }
]
---

<BaseLayout 
  title={isVi ? `Công cụ Tiện ích | ${site.title}` : `Developer Tools | ${site.title}`}
  description={isVi 
    ? "Bộ công cụ tiện ích miễn phí chạy 100% trên trình duyệt dành cho Developer và Designer." 
    : "Free utility tools running 100% in your browser for Developers and Designers."}
>
  <main class="page-tools wrap pt-32 pb-24">
    <header class="mb-16">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4" style="background: linear-gradient(135deg, var(--c-neon-cyan), var(--c-neon-magenta)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
        {isVi ? "Công cụ Tiện ích (Developer)" : "Developer Utilities"}
      </h1>
      <p class="text-xl opacity-70 max-w-2xl">
        {isVi 
          ? "Các công cụ miễn phí, tốc độ cao được xử lý 100% trên thiết bị của bạn (Client-side). Không tải dữ liệu lên server, bảo mật tuyệt đối."
          : "Free, high-speed tools processed 100% on your device (Client-side). No data uploaded to external servers, ensuring absolute privacy."}
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {tools.map(tool => {
        const Icon = tool.icon;
        const isReady = tool.status === 'ready';
        
        return (
          <a 
            href={isReady ? tool.href : '#'} 
            class={`tool-card group relative p-6 rounded-2xl border transition-all duration-300 ${
              isReady 
                ? 'border-white/10 bg-white/5 hover:bg-white/10 hover:border-white/20 hover:-translate-y-1' 
                : 'border-white/5 bg-white/[0.02] opacity-60 cursor-not-allowed'
            }`}
          >
            {isReady && (
              <div class="absolute inset-0 rounded-2xl ring-1 ring-inset ring-[var(--c-neon-cyan)] opacity-0 group-hover:opacity-30 blur-sm transition-opacity duration-300 pointer-events-none" />
            )}
            
            <div class="flex items-start justify-between mb-4">
              <div class={`p-3 rounded-xl ${isReady ? 'bg-white/10' : 'bg-white/5'}`}>
                <Icon size={28} className={isReady ? "text-[color:var(--c-neon-cyan)]" : "text-white/40"} />
              </div>
              
              {!isReady && (
                <span class="text-xs font-mono font-bold tracking-wider uppercase px-2 py-1 rounded-md bg-white/10 text-white/50">
                  {isVi ? "Sắp ra mắt" : "Coming Soon"}
                </span>
              )}
            </div>

            <h3 class={`text-xl font-bold mb-2 ${isReady ? 'text-white' : 'text-white/60'}`}>
              {tool.title}
            </h3>
            
            <p class="text-sm leading-relaxed text-white/60">
              {tool.description}
            </p>
          </a>
        )
      })}
    </div>
  </main>
</BaseLayout>
