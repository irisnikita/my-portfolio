---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { site } from "../../data/site";
import { Image as ImageIcon, FileCode2, PaintBucket, FileJson, CopyCheck } from "lucide-react";
import { getLangFromUrl, useTranslations, useTranslatedPath } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const tools = [
  {
    id: "image-compressor",
    title: t("tools.card.imageCompressor.title"),
    description: t("tools.card.imageCompressor.desc"),
    icon: ImageIcon,
    status: "ready", // ready, beta, planned
    href: translatePath("/tools/image-compressor"),
  },
  {
    id: "svg-optimizer",
    title: t("tools.card.svgOptimizer.title"),
    description: t("tools.card.svgOptimizer.desc"),
    icon: FileCode2,
    status: "planned",
    href: translatePath("/tools#svg"),
  },
  {
    id: "code-to-image",
    title: t("tools.card.codeToImage.title"),
    description: t("tools.card.codeToImage.desc"),
    icon: CopyCheck,
    status: "ready",
    href: translatePath("/tools/code-to-image"),
  },
  {
    id: "mesh-gradient",
    title: t("tools.card.meshGradient.title"),
    description: t("tools.card.meshGradient.desc"),
    icon: PaintBucket,
    status: "ready",
    href: translatePath("/tools/css-mesh-gradient"),
  },
  {
    id: "json-formatter",
    title: "Smart JSON Formatter",
    description: "Format messy JSON structures, highlight syntax and smartly check for errors.",
    icon: FileJson,
    status: "planned",
    href: translatePath("/tools#json"),
  },
];
---

<BaseLayout
  title={`${t("tools.pageTitle")} | ${site.title}`}
  description={t("tools.pageDescription")}
>
  <main class="page-tools wrap pt-32 pb-24">
    <header class="mb-16">
      <h1
        class="text-4xl md:text-5xl font-extrabold mb-4"
        style="background: linear-gradient(135deg, var(--c-neon-cyan), var(--c-neon-magenta)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"
      >
        {t("tools.heading")}
      </h1>
      <p class="text-xl opacity-70 max-w-2xl">
        {t("tools.subheading")}
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        tools.map((tool) => {
          const Icon = tool.icon;
          const isReady = tool.status === "ready";

          return (
            <a
              href={isReady ? tool.href : "#"}
              class={`tool-card group relative p-6 rounded-2xl border overflow-hidden transition-all duration-300 ${
                isReady
                  ? "border-white/10 bg-white/5 hover:border-white/20 hover:-translate-y-1"
                  : "border-white/5 bg-white/[0.02] opacity-60 cursor-not-allowed"
              }`}
            >
              {isReady && (
                <div 
                  class="pointer-events-none absolute -inset-px opacity-0 group-data-[hovered=true]:opacity-100 transition-opacity duration-300 z-0"
                  style="background: radial-gradient(400px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(0, 229, 255, 0.15), transparent 40%);"
                />
              )}
              {isReady && (
                <div class="pointer-events-none absolute inset-0 rounded-2xl ring-1 ring-inset ring-[var(--c-neon-cyan)] opacity-0 group-data-[hovered=true]:opacity-30 blur-sm transition-opacity duration-300 z-0" />
              )}

              <div class="relative z-10 flex items-start justify-between mb-4">
                <div class={`p-3 rounded-xl ${isReady ? "bg-white/10" : "bg-white/5"}`}>
                  <Icon
                    size={28}
                    className={isReady ? "text-[color:var(--c-neon-cyan)]" : "text-white/40"}
                  />
                </div>

                {!isReady && (
                  <span class="text-xs font-mono font-bold tracking-wider uppercase px-2 py-1 rounded-md bg-white/10 text-white/50">
                    {t("tools.comingSoon")}
                  </span>
                )}
              </div>

              <h3 class={`relative z-10 text-xl font-bold mb-2 ${isReady ? "text-white" : "text-white/60"}`}>
                {tool.title}
              </h3>

              <p class="relative z-10 text-sm leading-relaxed text-white/60">{tool.description}</p>
            </a>
          );
        })
      }
    </div>
  </main>
</BaseLayout>

<script>
  function initCardSpotlight() {
    const cards = document.querySelectorAll('.tool-card');
    cards.forEach((card) => {
      const updatePosition = (e: Event) => {
        const mouseEvent = e as MouseEvent;
        const c = card as HTMLElement;
        const rect = c.getBoundingClientRect();
        const x = mouseEvent.clientX - rect.left;
        const y = mouseEvent.clientY - rect.top;
        c.style.setProperty('--mouse-x', `${x}px`);
        c.style.setProperty('--mouse-y', `${y}px`);
        c.setAttribute('data-hovered', 'true');
      };
      
      card.addEventListener('mouseenter', updatePosition);
      card.addEventListener('mousemove', updatePosition);
      card.addEventListener('mouseleave', () => {
        card.removeAttribute('data-hovered');
      });
    });
  }

  // Run on first load and page transitions
  document.addEventListener('astro:page-load', initCardSpotlight);
  initCardSpotlight();
</script>
