---
// Client-side init for all motion systems.
// Kept as tiny scripts (no hydration framework).
---

<script>
  import { observeReveal, observeScrollProgress } from "../../lib/motion";

  type RevealInitWindow = Window & typeof globalThis & { _cleanupRevealInit?: () => void };

  function initMotion() {
    const cleanups = [];
    const revealInitWindow = window as RevealInitWindow;

    cleanups.push(observeReveal({}));

    const progressBar = document.querySelector<HTMLElement>(".scroll-progress-bar");
    cleanups.push(observeScrollProgress(progressBar));

    revealInitWindow._cleanupRevealInit = () => {
      cleanups.forEach((cleanup) => cleanup?.disconnect?.());
    };
  }

  // astro:page-load fires on initial page load AND after every ViewTransition
  document.addEventListener("astro:page-load", () => {
    const revealInitWindow = window as RevealInitWindow;
    if (revealInitWindow._cleanupRevealInit) revealInitWindow._cleanupRevealInit();
    initMotion();
  });
</script>
