---
// Client-side init for all motion systems.
// Kept as tiny scripts (no hydration framework).
---

<script>
  import {
    observeReveal,
    observeParallax,
    observeScrollProgress,
    initCardTilt,
    initHeroScrollFade,
  } from "../../lib/motion";

  function initMotion() {
    // Reveal on scroll
    observeReveal({});

    // Scroll parallax elements
    observeParallax();

    // Scroll progress bar
    const progressBar = document.querySelector<HTMLElement>(".scroll-progress-bar");
    observeScrollProgress(progressBar);

    // Card 3D tilt
    initCardTilt();

    // Hero scroll fade-out
    initHeroScrollFade();
  }

  // astro:page-load fires on initial page load AND after every ViewTransition
  document.addEventListener("astro:page-load", () => {
    initMotion();
  });
</script>
