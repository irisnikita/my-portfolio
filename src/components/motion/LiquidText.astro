---
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"div"> & {
  text: string;
};

const { class: className, text, ...rest } = Astro.props;
const filterId = `liquid-filter-${Math.random().toString(36).slice(2, 9)}`;
---

<div class={["liquid-text-container", className].filter(Boolean).join(" ")} {...rest}>
  <svg
    class="liquid-svg"
    aria-hidden="true"
    width="0"
    height="0"
    xmlns="http://www.w3.org/2000/svg"
  >
    <filter id={filterId}>
      <feTurbulence
        type="fractalNoise"
        baseFrequency="0.01 0.01"
        numOctaves="1"
        result="noise"
        class="turbulence"></feTurbulence>
      <feDisplacementMap
        in="SourceGraphic"
        in2="noise"
        scale="0"
        xChannelSelector="R"
        yChannelSelector="G"
        class="displacement"></feDisplacementMap>
    </filter>
  </svg>

  <h2 class="liquid-heading" style={`filter: url(#${filterId});`} data-liquid-text>
    {text}
  </h2>
</div>

<script>
  type LiquidTextWindow = Window & typeof globalThis & { _cleanupLiquidText?: () => void };

  function initLiquidText() {
    const liquidTextWindow = window as LiquidTextWindow;
    if (liquidTextWindow._cleanupLiquidText) liquidTextWindow._cleanupLiquidText();

    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    const cleanups: Array<() => void> = [];
    const containers = document.querySelectorAll<HTMLElement>(".liquid-text-container");

    containers.forEach((container) => {
      const filter = container.querySelector<SVGFEDisplacementMapElement>(".displacement");
      const turbulence = container.querySelector<SVGFETurbulenceElement>(".turbulence");
      if (!filter || !turbulence) return;

      let targetScale = 0;
      let currentScale = 0;
      let baseFreqX = 0.01;
      let baseFreqY = 0.01;
      let rafId = 0;

      const queueAnimation = () => {
        if (!rafId) rafId = requestAnimationFrame(animate);
      };

      const animate = () => {
        rafId = 0;
        currentScale += (targetScale - currentScale) * 0.16;

        if (Math.abs(currentScale - targetScale) < 0.2 && targetScale === 0) {
          currentScale = 0;
          filter.setAttribute("scale", "0");
          turbulence.setAttribute("baseFrequency", "0.01 0.01");
          return;
        }

        filter.setAttribute("scale", currentScale.toFixed(2));
        turbulence.setAttribute(
          "baseFrequency",
          `${Math.abs(baseFreqX).toFixed(4)} ${Math.abs(baseFreqY).toFixed(4)}`,
        );

        rafId = requestAnimationFrame(animate);
      };

      const onPointerMove = (event: PointerEvent) => {
        const rect = container.getBoundingClientRect();
        const cx = rect.left + rect.width / 2;
        const cy = rect.top + rect.height / 2;
        const dx = event.clientX - cx;
        const dy = event.clientY - cy;
        const dist = Math.sqrt(dx * dx + dy * dy);
        const maxDist = Math.max(rect.width, rect.height);
        const intensity = Math.max(0, 1 - dist / (maxDist * 0.8));

        targetScale = intensity * 90;
        baseFreqX = 0.01 + (dx / rect.width) * 0.012;
        baseFreqY = 0.01 + (dy / rect.height) * 0.012;
        queueAnimation();
      };

      const onPointerLeave = () => {
        targetScale = 0;
        baseFreqX = 0.01;
        baseFreqY = 0.01;
        queueAnimation();
      };

      container.addEventListener("pointermove", onPointerMove, { passive: true });
      container.addEventListener("pointerleave", onPointerLeave);

      cleanups.push(() => {
        container.removeEventListener("pointermove", onPointerMove);
        container.removeEventListener("pointerleave", onPointerLeave);
        if (rafId) cancelAnimationFrame(rafId);
        filter.setAttribute("scale", "0");
        turbulence.setAttribute("baseFrequency", "0.01 0.01");
      });
    });

    liquidTextWindow._cleanupLiquidText = () => {
      cleanups.forEach((cleanup) => cleanup());
    };
  }

  document.addEventListener("astro:page-load", initLiquidText);
</script>

<style>
  .liquid-text-container {
    position: relative;
    width: 100%;
    padding: 60px 0;
    cursor: crosshair;
    overflow: hidden;
  }

  .liquid-svg {
    position: absolute;
    pointer-events: none;
  }

  .liquid-heading {
    margin: 0;
    font-size: clamp(4rem, 15vw, 12rem);
    font-weight: 900;
    line-height: 0.9;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    text-align: center;
    color: transparent;
    -webkit-text-stroke: 2px var(--c-text);
    text-shadow: 0 0 20px rgba(var(--c-neon-cyan-rgb, 0, 229, 255), 0.2);
    transition: color 320ms ease;
  }

  .liquid-text-container:hover .liquid-heading {
    color: var(--c-text);
    -webkit-text-stroke: 0;
    text-shadow: var(--shadow-glow-cyan);
  }

  @media (prefers-reduced-motion: reduce) {
    .liquid-heading {
      filter: none !important;
      transition: none;
    }
  }
</style>
