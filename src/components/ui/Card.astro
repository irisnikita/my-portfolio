---
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"article"> & {
  reveal?: boolean;
};

const { class: className, reveal = true, ...rest } = Astro.props;
---

<article
  {...rest}
  class={["card card-tilt", className].filter(Boolean).join(" ")}
  {...reveal ? { "data-reveal": "", "data-reveal-group": "card" } : {}}
>
  <!-- Glow spotlight that follows cursor -->
  <div class="card-glow" aria-hidden="true"></div>
  <!-- Glare effect -->
  <div class="card-glare" aria-hidden="true"></div>
  <slot />
</article>

<script>
  function initHoverCards() {
    // Only init if not reduced motion and has pointer
    const pmr = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const hasCoarse = window.matchMedia("(pointer: coarse)").matches;
    if (pmr || hasCoarse) return;

    const cards = document.querySelectorAll(".card-tilt");

    cards.forEach((cardFn) => {
      const card = cardFn as HTMLElement;
      if (card.hasAttribute("data-tilt-init")) return;
      card.setAttribute("data-tilt-init", "true");

      const updatePosition = (e: MouseEvent) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;

        // Calculate rotation based on cursor position relative to center
        // -1 to 1 multiplier
        const xPct = (x / rect.width - 0.5) * 2;
        const yPct = (y / rect.height - 0.5) * 2;

        // Max rotation 8 degrees
        const rotX = yPct * -8;
        const rotY = xPct * 8;

        card.style.setProperty("--rot-x", `${rotX}deg`);
        card.style.setProperty("--rot-y", `${rotY}deg`);
        card.style.setProperty("--mouse-x", `${(x / rect.width) * 100}%`);
        card.style.setProperty("--mouse-y", `${(y / rect.height) * 100}%`);

        // Keep standard glow synced too
        card.style.setProperty("--glow-x", `${x}px`);
        card.style.setProperty("--glow-y", `${y}px`);
        
        card.setAttribute("data-hovered", "true");
      };

      card.addEventListener("mouseenter", updatePosition);
      card.addEventListener("mousemove", updatePosition);

      card.addEventListener("mouseleave", () => {
        card.removeAttribute("data-hovered");
        card.style.setProperty("--rot-x", "0deg");
        card.style.setProperty("--rot-y", "0deg");
        // We INTENTIONALLY don't reset --mouse-x, --mouse-y, --glow-x, --glow-y here 
        // to `50%` so the light effect smoothly fades out exactly where the cursor exited 
        // instead of abruptly jumping back to the center.
      });
    });
  }

  document.addEventListener("astro:page-load", initHoverCards);
  if (typeof window !== "undefined") {
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initHoverCards);
    } else {
      initHoverCards();
    }
  }
</script>

<style>
  .card {
    --glow-x: 50%;
    --glow-y: 50%;
    --rot-x: 0deg;
    --rot-y: 0deg;
    --mouse-x: 50%;
    --mouse-y: 50%;

    border-radius: var(--radius);
    border: 1px solid rgba(234, 240, 255, 0.1);
    background:
      radial-gradient(120% 160% at 20% 0%, rgba(124, 59, 255, 0.16), transparent 52%),
      rgba(255, 255, 255, 0.03);
    position: relative;
    /* Spring physics feeling for rotation */
    transition:
      transform 400ms cubic-bezier(0.175, 0.885, 0.32, 1.275),
      border-color 220ms var(--ease-out),
      box-shadow 220ms var(--ease-out);
    will-change: transform;
    /* Wrap in perspective so children can be 3D transformed natively */
    transform-style: preserve-3d;
    transform: perspective(1000px) rotateX(var(--rot-x)) rotateY(var(--rot-y));
    height: 100%;
  }

  /* To prevent clipping z-translated children */
  .card :global(*) {
    transform-style: preserve-3d;
  }

  /* Glow spotlight */
  .card-glow {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    opacity: 0;
    background: radial-gradient(
      320px 320px at var(--glow-x) var(--glow-y),
      rgba(0, 229, 255, 0.12),
      rgba(255, 43, 214, 0.06) 40%,
      transparent 70%
    );
    transition: opacity 300ms var(--ease-out);
    z-index: 1;
  }

  /* Hologram Glare */
  .card-glare {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    opacity: 0;
    mix-blend-mode: soft-light;
    background: radial-gradient(
      farthest-corner circle at var(--mouse-x) var(--mouse-y),
      rgba(255, 255, 255, 0.8) 0%,
      rgba(255, 255, 255, 0.2) 20%,
      rgba(255, 255, 255, 0) 100%
    );
    transition: opacity 300ms var(--ease-out);
    z-index: 2;
    transform: translateZ(10px); /* float slightly above content */
  }

  /* Inner highlight line */
  .card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    opacity: 0;
    background: linear-gradient(
      135deg,
      rgba(0, 229, 255, 0.22),
      rgba(255, 43, 214, 0.14) 45%,
      rgba(124, 59, 255, 0.1)
    );
    mask:
      linear-gradient(#000, #000) content-box,
      linear-gradient(#000, #000);
    -webkit-mask:
      linear-gradient(#000, #000) content-box,
      linear-gradient(#000, #000);
    padding: 1px;
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    z-index: 3;
    transform: translateZ(1px);
  }

  .card[data-hovered="true"] {
    border-color: rgba(0, 229, 255, 0.22);
    box-shadow:
      var(--shadow-glow-cyan),
      0 30px 60px -15px rgba(0, 0, 0, 0.6);
  }

  .card[data-hovered="true"]::before {
    opacity: 1;
  }

  .card[data-hovered="true"] .card-glow {
    opacity: 1;
  }

  .card[data-hovered="true"] .card-glare {
    opacity: 0.6;
  }

  @media (prefers-reduced-motion: reduce) {
    .card {
      transition: none;
      transform: none !important;
    }
    .card:hover {
      box-shadow: none;
    }
    .card::before,
    .card-glow,
    .card-glare {
      opacity: 0 !important;
      transition: none;
    }
  }

  @media (hover: none), (pointer: coarse) {
    .card {
      transform: none !important;
    }
    .card-glow,
    .card-glare {
      display: none;
    }
  }
</style>
