---
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"span"> & { tone?: "cyan" | "magenta" | "neutral" };
const { tone = "neutral", class: className, ...rest } = Astro.props;
---

<span {...rest} class={['tag', `tone-${tone}`, className].filter(Boolean).join(' ')}>
  <slot />
</span>

<style>
  .tag {
    display: inline-flex;
    align-items: center;
    padding: 6px 10px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.10);
    background: rgba(255, 255, 255, 0.03);
    color: rgba(255, 255, 255, 0.78);
    font-size: 13px;
    line-height: 1;
  }
  .tone-cyan {
    border-color: rgba(50, 245, 255, 0.22);
    box-shadow: 0 0 0.8rem rgba(50, 245, 255, 0.12);
  }
  .tone-magenta {
    border-color: rgba(255, 53, 213, 0.20);
    box-shadow: 0 0 0.8rem rgba(255, 53, 213, 0.10);
  }
</style>
