---
import Container from "./Container.astro";

const {
  title,
  eyebrow,
  class: className,
  headingLevel = 2,
} = Astro.props;

const HeadingTag = (`h${headingLevel}` as const);
---

<section class={['section', className].filter(Boolean).join(' ')}>
  <Container>
    {eyebrow ? <p class="eyebrow">{eyebrow}</p> : null}
    {title ? <HeadingTag class="title">{title}</HeadingTag> : null}
    <div class="body">
      <slot />
    </div>
  </Container>
</section>

<style>
  .section {
    padding-block: clamp(48px, 8vw, 92px);
  }
  .eyebrow {
    margin: 0 0 10px;
    color: rgba(255, 255, 255, 0.55);
    font-weight: 650;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-size: 12px;
  }
  .title {
    margin: 0 0 14px;
    font-size: clamp(22px, 2.6vw, 32px);
    letter-spacing: var(--tracking-tight);
  }
</style>
