---
import { site } from "../../data/site";
---

<div id="cmd-palette" class="palette-backdrop" aria-hidden="true" role="dialog" aria-modal="true">
  <div class="palette-container">
    <div class="palette-search">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <input type="text" id="cmd-input" placeholder="Type a command or search..." autocomplete="off" spellcheck="false" />
      <kbd class="kbd">ESC</kbd>
    </div>

    <div class="palette-content" id="cmd-list" role="listbox">
      <!-- Navigation -->
      <div class="palette-group" data-group="Navigation">
        <div class="palette-group-title">Navigation</div>
        <a href="/" class="palette-item" role="option" aria-selected="false">
          <span class="icon">🏠</span> <span>Home</span>
        </a>
        <a href="/about" class="palette-item" role="option" aria-selected="false">
          <span class="icon">✨</span> <span>About</span>
        </a>
        <a href="/projects" class="palette-item" role="option" aria-selected="false">
          <span class="icon">💼</span> <span>Projects</span>
        </a>
        <a href="/blog" class="palette-item" role="option" aria-selected="false">
          <span class="icon">📝</span> <span>Blog</span>
        </a>
        <a href="/contact" class="palette-item" role="option" aria-selected="false">
          <span class="icon">✉️</span> <span>Contact</span>
        </a>
      </div>

      <!-- Links -->
      <div class="palette-group" data-group="Links">
        <div class="palette-group-title">Links & Socials</div>
        {site.cvUrl && (
          <a href={site.cvUrl} target="_blank" class="palette-item" role="option" aria-selected="false">
            <span class="icon">📄</span> <span>View Resume (CV)</span>
          </a>
        )}
        {site.socials.githubUrl && (
          <a href={site.socials.githubUrl} target="_blank" class="palette-item" role="option" aria-selected="false">
            <span class="icon">👾</span> <span>GitHub</span>
          </a>
        )}
        {site.socials.linkedinUrl && (
          <a href={site.socials.linkedinUrl} target="_blank" class="palette-item" role="option" aria-selected="false">
            <span class="icon">💼</span> <span>LinkedIn</span>
          </a>
        )}
        <button class="palette-item" id="cmd-copy-email" data-email={site.email} role="option" aria-selected="false">
          <span class="icon">📋</span> <span>Copy Email Address</span>
        </button>
      </div>

      <!-- Themes -->
      <div class="palette-group" data-group="Themes">
        <div class="palette-group-title">Themes & Vibes</div>
        <button class="palette-item cmd-theme" data-theme="cyberpunk" role="option" aria-selected="false">
          <span class="icon">🟣</span> <span>Vibe: Cyberpunk (Default)</span>
        </button>
        <button class="palette-item cmd-theme" data-theme="matrix" role="option" aria-selected="false">
          <span class="icon">💻</span> <span>Vibe: The Matrix</span>
        </button>
        <button class="palette-item cmd-theme" data-theme="vaporwave" role="option" aria-selected="false">
          <span class="icon">🌴</span> <span>Vibe: Vaporwave</span>
        </button>
        <button class="palette-item cmd-theme" data-theme="monochrome" role="option" aria-selected="false">
          <span class="icon">⚫</span> <span>Vibe: Monochrome</span>
        </button>
      </div>

      <!-- Experiments -->
      <div class="palette-group" data-group="Experiments">
        <div class="palette-group-title">Experiments</div>
        <button class="palette-item" id="cmd-gravity" role="option" aria-selected="false">
          <span class="icon">🍎</span> <span>Gravity Physics (Easter Egg)</span>
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  function initPalette() {
    const backdrop = document.getElementById('cmd-palette');
    const input = document.getElementById('cmd-input') as HTMLInputElement | null;
    const list = document.getElementById('cmd-list');
    if (!backdrop || !input || !list) return;

    const items = Array.from(list.querySelectorAll('.palette-item')) as HTMLElement[];
    let selectedIndex = 0;
    let isOpen = false;

    // Remove duplicates from setup
    const cleanupExt = (window as any)._cleanupCmd;
    if (cleanupExt) cleanupExt();

    function updateSelection() {
      const visibleItems = items.filter(i => i.style.display !== 'none');
      if (visibleItems.length === 0) return;
      
      // Clamp
      if (selectedIndex < 0) selectedIndex = visibleItems.length - 1;
      if (selectedIndex >= visibleItems.length) selectedIndex = 0;

      visibleItems.forEach((item, idx) => {
        if (idx === selectedIndex) {
          item.setAttribute('aria-selected', 'true');
          item.classList.add('selected');
          item.scrollIntoView({ block: 'nearest' });
        } else {
          item.setAttribute('aria-selected', 'false');
          item.classList.remove('selected');
        }
      });
    }

    function open() {
      isOpen = true;
      backdrop?.setAttribute('aria-hidden', 'false');
      backdrop?.classList.add('open');
      input?.focus();
      input!.value = '';
      filterList('');
    }

    function close() {
      isOpen = false;
      backdrop?.setAttribute('aria-hidden', 'true');
      backdrop?.classList.remove('open');
      input?.blur();
    }

    function filterList(query: string) {
      const q = query.toLowerCase();
      items.forEach(item => {
        const text = item.textContent?.toLowerCase() || '';
        item.style.display = text.includes(q) ? 'flex' : 'none';
      });

      // Hide empty groups
      list?.querySelectorAll('.palette-group').forEach(group => {
        const hasVisible = Array.from(group.querySelectorAll('.palette-item'))
          .some((i: any) => i.style.display !== 'none');
        (group as HTMLElement).style.display = hasVisible ? 'block' : 'none';
      });

      selectedIndex = 0;
      updateSelection();
    }

    const onKeydown = (e: KeyboardEvent) => {
      // Toggle on Cmd+K or Ctrl+K
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        if (isOpen) close();
        else open();
        return;
      }

      if (!isOpen) return;

      if (e.key === 'Escape') {
        e.preventDefault();
        close();
      } else if (e.key === 'ArrowDown') {
        e.preventDefault();
        selectedIndex++;
        updateSelection();
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        selectedIndex--;
        updateSelection();
      } else if (e.key === 'Enter') {
        e.preventDefault();
        const visibleItems = items.filter(i => i.style.display !== 'none');
        const selected = visibleItems[selectedIndex];
        if (selected) {
          if (selected.tagName === 'A') {
            selected.click();
            close();
          } else if (selected.id === 'cmd-copy-email') {
            const email = selected.getAttribute('data-email');
            if (email) {
              navigator.clipboard.writeText(email).then(() => {
                const textSpan = selected.querySelector('span:last-child');
                const origText = textSpan?.textContent;
                if (textSpan) textSpan.textContent = 'Copied!';
                setTimeout(() => {
                  if (textSpan) textSpan.textContent = origText || '';
                }, 2000);
              });
            }
          } else if (selected.classList.contains('cmd-theme')) {
            const theme = selected.getAttribute('data-theme');
            if (theme) {
              setTheme(theme);
              close();
            }
          } else if (selected.id === 'cmd-gravity') {
            close();
            // Dynamic import to save bundle size until user activates it
            import('../../utils/gravityEgg').then(mod => {
              mod.startGravity();
            }).catch(e => console.error("Gravity failed:", e));
          }
        }
      }
    };

    function setTheme(theme: string) {
      if (theme === 'cyberpunk') {
        document.documentElement.removeAttribute('data-vibe'); // Default
        localStorage.removeItem('theme-vibe');
      } else {
        document.documentElement.setAttribute('data-vibe', theme);
        localStorage.setItem('theme-vibe', theme);
      }
    }

    const onInput = (e: Event) => filterList((e.target as HTMLInputElement).value);

    const onClickOutside = (e: MouseEvent) => {
      if (e.target === backdrop) close();
    };

    const onPointerMoveItem = (e: PointerEvent) => {
      const item = e.currentTarget as HTMLElement;
      if (item.style.display === 'none') return;
      
      const visibleItems = items.filter(i => i.style.display !== 'none');
      const idx = visibleItems.indexOf(item);
      if (idx !== -1 && selectedIndex !== idx) {
        selectedIndex = idx;
        updateSelection();
      }
    };

    const onClickItem = (e: MouseEvent) => {
      const item = e.currentTarget as HTMLElement;
      if (item.tagName === 'A') {
        close();
      } else if (item.classList.contains('cmd-theme')) {
        const theme = item.getAttribute('data-theme');
        if (theme) {
          setTheme(theme);
          close();
        }
      } else if (item.id === 'cmd-gravity') {
        close();
        import('../../utils/gravityEgg').then(mod => {
          mod.startGravity();
        }).catch(e => console.error("Gravity failed:", e));
      }
    };

    window.addEventListener('keydown', onKeydown);
    input.addEventListener('input', onInput);
    backdrop.addEventListener('click', onClickOutside);
    
    items.forEach(item => {
      item.addEventListener('pointermove', onPointerMoveItem);
      item.addEventListener('click', onClickItem);
    });

    // Copy email specific
    const copyBtn = document.getElementById('cmd-copy-email');
    if (copyBtn) {
      copyBtn.addEventListener('click', () => {
        const email = copyBtn.getAttribute('data-email');
        if (email) {
          navigator.clipboard.writeText(email).then(() => {
            const textSpan = copyBtn.querySelector('span:last-child');
            const origText = textSpan?.textContent;
            if (textSpan) textSpan.textContent = 'Copied!';
            setTimeout(() => {
              if (textSpan) textSpan.textContent = origText || '';
            }, 2000);
          });
        }
      });
    }

    (window as any)._cleanupCmd = () => {
      window.removeEventListener('keydown', onKeydown);
      backdrop?.replaceWith(backdrop.cloneNode(true)); // remove all listeners lazily
    };
  }

  // ViewTransitions ready
  document.addEventListener('astro:page-load', initPalette);
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPalette);
  } else {
    initPalette();
  }
</script>

<style>
  .palette-backdrop {
    position: fixed;
    inset: 0;
    z-index: 99999;
    background: rgba(6, 8, 18, 0.4);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 12vh;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--dur-med) var(--ease-out);
  }

  .palette-backdrop.open {
    opacity: 1;
    pointer-events: auto;
  }

  .palette-container {
    width: 100%;
    max-width: 600px;
    margin: 0 16px;
    background: rgba(10, 14, 28, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    box-shadow: 0 32px 64px -16px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(0, 229, 255, 0.05);
    overflow: hidden;
    transform: scale(0.98) translateY(10px);
    transition: transform var(--dur-med) var(--ease-out);
  }

  .palette-backdrop.open .palette-container {
    transform: scale(1) translateY(0);
  }

  .palette-search {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(0, 0, 0, 0.2);
  }

  .palette-search svg {
    color: rgba(255, 255, 255, 0.4);
    flex-shrink: 0;
  }

  .palette-search input {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--c-text);
    font-size: 16px;
    outline: none;
  }

  .palette-search input::placeholder {
    color: rgba(255, 255, 255, 0.3);
  }

  .kbd {
    font-family: var(--f-mono);
    font-size: 11px;
    padding: 4px 6px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 4px;
    color: rgba(255, 255, 255, 0.5);
    text-transform: uppercase;
  }

  .palette-content {
    max-height: 50vh;
    overflow-y: auto;
    padding: 12px 8px;
  }

  .palette-content::-webkit-scrollbar {
    width: 8px;
  }
  .palette-content::-webkit-scrollbar-track {
    background: transparent;
  }
  .palette-content::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 4px;
  }

  .palette-group {
    margin-bottom: 8px;
  }
  .palette-group:last-child {
    margin-bottom: 0;
  }

  .palette-group-title {
    padding: 8px 12px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.4);
  }

  .palette-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px;
    border-radius: 8px;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    cursor: pointer;
    background: transparent;
    border: none;
    width: 100%;
    text-align: left;
    font-size: 15px;
    transition: all 100ms ease;
  }

  .palette-item .icon {
    font-size: 16px;
    opacity: 0.7;
    filter: grayscale(1);
    transition: filter 100ms ease, opacity 100ms ease;
  }

  .palette-item.selected,
  .palette-item:hover {
    background: rgba(255, 255, 255, 0.05);
    color: var(--c-text);
  }

  .palette-item.selected .icon,
  .palette-item:hover .icon {
    filter: grayscale(0);
    opacity: 1;
  }

  /* Neon glow hint for active item */
  .palette-item.selected {
    box-shadow: inset 2px 0 0 var(--c-neon-cyan);
    background: linear-gradient(90deg, rgba(0, 229, 255, 0.08), transparent);
  }
</style>
