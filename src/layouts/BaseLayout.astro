---
import "../styles/global.css";
import { ViewTransitions } from "astro:transitions";
import RevealInit from "../components/motion/RevealInit.astro";
import CustomCursor from "../components/motion/CustomCursor.astro";
import Preloader from "../components/motion/Preloader.astro";
import FluidBackground from "../components/hero/FluidBackground.astro";
import CommandPalette from "../components/ui/CommandPalette.astro";
import ScrambleText from "../components/motion/ScrambleText.astro";
import ScrollDistortion from "../components/motion/ScrollDistortion.astro";
import SoundManager from "../components/ui/SoundManager.astro";
import LenisScroll from "../components/motion/LenisScroll.astro";
import AIChatbot from "../components/widgets/AIChatbot";
import Header from "../components/ui/Header";
import { site } from "../data/site";

const {
  title = `${site.name} — ${site.title}`,
  description = `${site.tagline} • ${site.location}`,
  ogImage = "/og.png",
  ogType = "website",
} = Astro.props;

const nav = [
  { href: "/projects", label: "Projects" },
  { href: "/about", label: "About" },
  { href: "/blog", label: "Blog" },
  { href: "/#contact", label: "Contact" },
];

const footerSocials = [
  { label: "GitHub", href: site.socials.githubUrl },
  { label: "LinkedIn", href: site.socials.linkedinUrl },
  { label: "X", href: site.socials.xUrl },
].filter((s) => typeof s.href === "string" && s.href.length > 0);

const pathname = Astro.url?.pathname ?? "/";
const isContactActive = pathname === "/" && Astro.url?.hash === "#contact";

const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : undefined;
const ogImageAbs = Astro.site ? new URL(ogImage, Astro.site).toString() : ogImage;

const personSameAs = [site.socials.githubUrl, site.socials.linkedinUrl, site.socials.xUrl].filter(Boolean);

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: `${site.name} — ${site.title}`,
    url: Astro.site ? Astro.site.toString().replace(/\/$/, "") : canonical,
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: site.name,
    jobTitle: site.title,
    email: site.email ? `mailto:${site.email}` : undefined,
    address: {
      "@type": "PostalAddress",
      addressLocality: "Ho Chi Minh City",
      addressCountry: "VN",
    },
    sameAs: personSameAs.length ? personSameAs : undefined,
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />

    {canonical ? <link rel="canonical" href={canonical} /> : null}

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    {canonical ? <meta property="og:url" content={canonical} /> : null}
    <meta property="og:image" content={ogImageAbs} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />

    <link rel="manifest" href="/site.webmanifest" />

    <title>{title}</title>

    {/* Scope transitions to projects pages only (avoid global) */}
    {pathname.startsWith('/projects') ? <ViewTransitions /> : null}

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    
    <!-- Apply vibe theme from local storage before page render to prevent FOUC -->
    <script is:inline>
      try {
        const theme = localStorage.getItem('theme-vibe');
        if (theme && theme !== 'cyberpunk') {
          document.documentElement.setAttribute('data-vibe', theme);
        }
      } catch (e) {}
    </script>
    
    <!-- Track click coords for ViewTransitions Wipe Effect -->
    <script is:inline>
      document.addEventListener('click', (e) => {
        // Find closest anchor
        const a = e.target.closest('a');
        if (a && a.href && a.hostname === location.hostname && !a.hash) {
          // Set CSS vars on html element
          document.documentElement.style.setProperty('--click-x', e.clientX + 'px');
          document.documentElement.style.setProperty('--click-y', e.clientY + 'px');
        }
      });
    </script>
  </head>
  <body>
    <!-- Smooth Scroll Init -->
    <LenisScroll />
    
    <!-- 3D WebGL Fluid Canvas -->
    <FluidBackground />
    <Preloader />
    <CustomCursor />
    <div class="scroll-progress-bar" aria-hidden="true" />
    <RevealInit />
    <CommandPalette />
    <ScrollDistortion />
    <ScrambleText />
    <SoundManager />
    <a href="#main" class="skip-link">Skip to content</a>

    <Header client:load currentPath={pathname} />

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap">
        <div class="footerInner">
          <p class="fine">© {new Date().getFullYear()} • {site.name}</p>
          {footerSocials.length > 0 && (
            <div class="footerSocials">
              {footerSocials.map((s) => (
                <a href={s.href} class="footerLink" target="_blank" rel="noreferrer">{s.label}</a>
              ))}
            </div>
          )}
        </div>
      </div>
    </footer>
    <AIChatbot client:only="react" />
  </body>
</html>

<style is:global>
  .scroll-progress-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--c-neon-cyan), var(--c-neon-magenta), var(--c-neon-violet));
    transform-origin: left center;
    transform: scaleX(0);
    z-index: 50;
    will-change: transform;
    pointer-events: none;
    box-shadow: 0 0 8px rgba(0, 229, 255, 0.4);
  }

  .skip-link {
    position: absolute;
    left: 12px;
    top: 12px;
    transform: translateY(-140%);
    background: rgba(7, 6, 13, 0.92);
    border: 1px solid var(--c-border);
    color: var(--c-text);
    padding: 10px 12px;
    border-radius: 10px;
    transition: transform var(--dur-quick) var(--ease-out);
    z-index: 50;
  }
  .skip-link:focus-visible {
    transform: translateY(0);
  }

  .wrap {
    max-width: var(--container);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--c-text);
    font-weight: 650;
    letter-spacing: var(--tracking-tight);
  }
  .mark {
    width: 12px;
    height: 12px;
    border-radius: 999px;
    background: radial-gradient(circle at 30% 30%, #ffffff, rgba(50, 245, 255, 0.85) 35%, rgba(255, 53, 213, 0.6));
    box-shadow: var(--shadow-glow-cyan);
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .navLink {
    text-decoration: none;
    color: var(--c-muted);
    padding: 8px 10px;
    border-radius: 10px;
    transition: color var(--dur-quick) var(--ease-out), background-color var(--dur-quick) var(--ease-out);
  }
  .navLink:hover {
    color: var(--c-text);
    background: rgba(255, 255, 255, 0.04);
  }
  .navLink.isActive {
    color: var(--c-text);
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .cvLink {
    color: rgba(0, 229, 255, 0.78);
    border: 1px solid rgba(0, 229, 255, 0.18);
    font-size: 13px;
    font-weight: 650;
    letter-spacing: 0.04em;
  }
  .cvLink:hover {
    color: rgba(0, 229, 255, 1);
    background: rgba(0, 229, 255, 0.08);
  }

  .site-footer {
    margin-top: 72px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }
  .site-footer .wrap {
    padding-block: 28px;
  }

  .footerInner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }

  .fine {
    margin: 0;
    color: rgba(255, 255, 255, 0.55);
    font-size: 14px;
  }

  .footerSocials {
    display: flex;
    gap: 14px;
  }

  .footerLink {
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    font-size: 13px;
    transition: color var(--dur-quick) var(--ease-out);
  }
  .footerLink:hover {
    color: rgba(0, 229, 255, 0.85);
  }

  @media (max-width: 520px) {
    .nav {
      gap: 2px;
    }
    .navLink {
      padding: 8px 8px;
      font-size: 14px;
    }
    .desktop-nav {
      display: none !important;
    }
    .mobile-toggle {
      display: flex !important;
    }
  }
  @media (min-width: 521px) {
    .mobile-dropdown {
      display: none !important;
    }
    .mobile-toggle {
      display: none !important;
    }
  }
</style>
